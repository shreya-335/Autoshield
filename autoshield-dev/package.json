{
  "name": "autoshield-dev",
  "displayName": "Autoshield-DevAgent",
  "description": "--",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "autoshield-sidebar",
          "title": "AutoShield",
          "icon": "media/icon.png"
        }
      ]
    },
    "views": {
      "autoshield-sidebar": [
        {
          "type": "webview",
          "id": "autoshield.view",
          "name": "Security Scan"
        }
      ]
    },
    "commands": [
      {
        "command": "autoshield.scan",
        "title": "AutoShield: Scan Project"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "axios": "^1.13.5"
  }
}
